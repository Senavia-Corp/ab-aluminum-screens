# Sanity — public read (no token needed for the frontend)
SANITY_PROJECT_ID=zsdw057t
SANITY_DATASET=production

# Server-side only: used by /api/lead (write leads + upload photos) and scripts/.
# Copy the real token from source/CMS Webflow AB Aluminum And Screens/sanity.env
# Never commit the real value.
SANITY_WRITE_TOKEN=

# Gmail SMTP — /api/lead emails the team on every new lead, FROM the admin Gmail.
# GMAIL_APP_PASSWORD = 16-char App Password (Google Account > Security > App passwords),
# NOT the account password. Requires 2-Step Verification enabled.
GMAIL_USER=digitalabaluminumandscreens@gmail.com
GMAIL_APP_PASSWORD=
# Comma-separated recipients for the internal new-lead notification.
LEAD_NOTIFY_TO=digitalabaluminumandscreens@gmail.com,info@abaluminumandscreens.com

# Cloudflare Turnstile — server-side secret to verify the human-check token on /api/lead.
# Get it from Cloudflare dash > Turnstile > your widget. The public site key lives in src/lib/turnstile.ts.
TURNSTILE_SECRET=
