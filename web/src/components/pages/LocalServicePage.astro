---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useT, localizedHref, loc, type Lang } from '../../lib/i18n';
import { SERVICE_TO_GALLERY, GALLERY_ROUTE_TO_SLUG, SERVICE_ROUTES, type ServiceRoute } from '../../lib/routes';
import { SERVICES } from '../../lib/nav';
import { getLocalService, getLocalServiceKeys, getServiceAreas, getGallery } from '../../lib/queries';
import { COUNTY_BY_SLUG } from '../../lib/areas';
import { BUSINESS_ID, SITE_ORIGIN } from '../../lib/seo';
import { urlFor } from '../../lib/sanity';
import { DEFAULT_PRICING, estimateBreakdown, formatUSD } from '../../lib/pricing';
import { SVC_STRUCT, TYPICAL, SVC_SERVICE_TYPE, LEAD_SERVICE } from '../../lib/services-meta';
import Breadcrumbs from '../Breadcrumbs.astro';
import TrustBadges from '../TrustBadges.astro';
import SanityImg from '../SanityImg.astro';
import PortableText from '../PortableText.astro';
import AnswerBlock from '../AnswerBlock.astro';
import FAQ from '../FAQ.astro';
import StatsBand from '../StatsBand.astro';
import GalleryMosaic from '../GalleryMosaic.astro';
import FeatureGrid from '../FeatureGrid.astro';
import ProcessSteps from '../ProcessSteps.astro';
import FinancingTeaser from '../FinancingTeaser.astro';
import Reviews from '../Reviews.astro';
import CtaStrip from '../CtaStrip.astro';
import LeadSection from '../LeadSection.astro';

interface Props {
  lang: Lang;
  route: ServiceRoute;
  citySlug: string;
}

// Deterministic per-city selection from an image pool (seeded Fisher-Yates, no Math.random so
// the choice is stable across builds). Gives each city a distinct, non-repeating set of photos.
function pickImages(seed: string, arr: any[], count: number) {
  let h = 2166136261;
  for (let i = 0; i < seed.length; i++) { h ^= seed.charCodeAt(i); h = Math.imul(h, 16777619); }
  const rand = () => {
    h += 0x6d2b79f5;
    let t = Math.imul(h ^ (h >>> 15), 1 | h);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
  const idx = arr.map((_, i) => i);
  for (let i = idx.length - 1; i > 0; i--) { const j = Math.floor(rand() * (i + 1));[idx[i], idx[j]] = [idx[j], idx[i]]; }
  return idx.slice(0, count).map((i) => arr[i]);
}

const { lang, route, citySlug } = Astro.props;
const doc = await getLocalService(route, citySlug);
const t = useT(lang);
const meta = SERVICES.find((s) => s.route === route)!;
const service = doc?.service;
const inWord = lang === 'es' ? 'en' : 'in';

// Per-city image variety: a distinct 8-photo set from this service's gallery collection so no two
// city pages look identical (falls back to the service doc's own images if the pool is too small).
const gallery = await getGallery(GALLERY_ROUTE_TO_SLUG[SERVICE_TO_GALLERY[route]]);
const pool = (gallery?.images || []).filter((im: any) => im?.asset);

// Which (service,city) combos have a live page — reused for the hero index + cross-links below.
const keys = await getLocalServiceKeys();
const keySet = new Set(keys.map((k) => `${k.service}:${k.city}`));
const allAreas: { slug: string; title: string; titleEs?: string }[] = await getServiceAreas();
// Cities of THIS service in a stable (title) order → give each an EVENLY-spread hero from the pool
// (so adjacent/prominent cities never share a hero), then fill the rest from a per-city shuffle.
const routeSlugs = allAreas.filter((a) => keySet.has(`${route}:${a.slug}`)).map((a) => a.slug);
const gi = Math.max(0, routeSlugs.indexOf(citySlug));
let picks: any[] = [];
if (pool.length >= 8) {
  const heroIdx = gi % pool.length;
  picks = [pool[heroIdx], ...pickImages(citySlug, pool.filter((_: any, i: number) => i !== heroIdx), 7)];
}

const cityName = loc<string>(doc, 'cityTitle', lang) || doc?.cityTitle || citySlug;
const county = COUNTY_BY_SLUG[citySlug] || (lang === 'es' ? 'el Sur de Florida' : 'South Florida');

// Region-true pricing from the SAME engine the estimator uses, so copy + calculator never disagree.
const perSqft = DEFAULT_PRICING.structures[SVC_STRUCT[route]].basePerSqft;
const typical = estimateBreakdown(TYPICAL[route]);
const rangeText = `${formatUSD(typical.total.low)}–${formatUSD(typical.total.high)}`;
// Copy stores {range}/{perSqft} tokens; real numbers are injected here (never stored stale).
const fill = (s?: string) => (s || '').replaceAll('{range}', rangeText).replaceAll('{perSqft}', String(perSqft));

// Localized copy (EN canonical, ES falls back to EN via loc()).
const h1 = loc<string>(doc, 'h1', lang) || `${meta.label[lang]} ${inWord} ${cityName}`;
const heroParagraph = fill(loc<string>(doc, 'heroParagraph', lang));
const introHeading = loc<string>(doc, 'introHeading', lang);
const valueParagraphs = (loc<{ paragraph: string }[]>(doc, 'valueParagraphs', lang) || []).map((v) => fill(v.paragraph));
const neighborhoods: string[] = doc?.neighborhoods || [];
const permitNote = fill(loc<string>(doc, 'permitNote', lang));
const localProof = fill(loc<string>(doc, 'localProof', lang));
const answerQ = loc<string>(doc, 'answerQuestion', lang) || `${meta.label[lang]} ${inWord} ${cityName}?`;
const answerA = fill(loc<string>(doc, 'answerAnswer', lang));
const faqs = (loc<{ q: string; a: string }[]>(doc, 'faqs', lang) || []).map((f) => ({ q: f.q, a: fill(f.a) }));
const galleryP = loc<string>(doc, 'galleryParagraph', lang) || undefined;
const seo = (lang === 'es' && doc?.seoEs) || doc?.seo || {};

// Shared service imagery + localized supporting copy (featured/colors) from the parent service doc.
const heroImg = picks[0] || service?.hero?.image;
const stripImgs = (picks.length >= 5 ? picks.slice(1, 5) : service?.pageImages?.slice(0, 4)) || [];
const answerImgSrc = picks[5] || service?.featured?.image || heroImg;
const featuredImg = picks[6] || service?.featured?.image;
const colorsImg = picks[7] || service?.colors?.image;
const heroAlt = loc<string>(doc, 'heroImageAlt', lang) || heroImg?.alt || h1;
const heroUrl = heroImg ? urlFor(heroImg)?.width(1400).auto('format').quality(80).url() : undefined;
const ogImage = heroImg ? urlFor(heroImg)?.width(1200).height(630).fit('crop').auto('format').url() : undefined;
const answerImg = urlFor(answerImgSrc)?.width(760).height(760).fit('crop').auto('format').url();
const featLoc = loc<any>(service, 'featured', lang) || service?.featured || {};
const colorsLoc = loc<any>(service, 'colors', lang) || service?.colors || {};
const galleryRoute = SERVICE_TO_GALLERY[route];

// Internal-link blocks: only cities/services that already have a live page (keySet/allAreas from above).
const neighbors = allAreas
  .filter((a) => a.slug !== citySlug && COUNTY_BY_SLUG[a.slug] === COUNTY_BY_SLUG[citySlug] && keySet.has(`${route}:${a.slug}`))
  .slice(0, 3);
const otherServices = SERVICE_ROUTES.filter((r) => r !== route && keySet.has(`${r}:${citySlug}`));

// Service JSON-LD — references the business by @id (declared once in BaseLayout); area = this city.
const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${meta.label[lang]} ${inWord} ${cityName}`,
  serviceType: SVC_SERVICE_TYPE[route][lang],
  ...(heroParagraph ? { description: heroParagraph } : {}),
  areaServed: { '@type': 'City', name: cityName },
  provider: { '@id': BUSINESS_ID },
  url: `${SITE_ORIGIN}${localizedHref('/' + route + '/' + citySlug, lang)}`,
};

const pageTitle = seo.metaTitle || `${meta.label[lang]} ${inWord} ${cityName} | AB Aluminum & Screens`;
const pageDesc = seo.metaDescription || heroParagraph;

// Section labels
const areaChipsH = lang === 'es' ? 'Barrios que atendemos' : 'Neighborhoods we serve';
const permitH = lang === 'es' ? 'Permisos e ingeniería' : 'Permits & engineering';
const nearbyH2 = lang === 'es' ? `${meta.label[lang]} en Áreas Cercanas` : `${meta.label[lang]} in Nearby Areas`;
const otherH2 = lang === 'es' ? `Otros Servicios en ${cityName}` : `Other Services in ${cityName}`;
---

<BaseLayout lang={lang} title={pageTitle} description={pageDesc} image={ogImage} jsonLd={serviceJsonLd}>
  {heroUrl && <link slot="head" rel="preload" as="image" href={heroUrl} fetchpriority="high" />}

  <Breadcrumbs
    lang={lang}
    items={[{ label: meta.label[lang], href: localizedHref('/' + route, lang) }, { label: cityName }]}
  />

  <!-- Hero (shared service image + city-specific H1/subtitle) -->
  <section class="ls-hero">
    {heroImg && (
      <SanityImg image={heroImg} width={1400} class="ls-hero__bg" loading="eager" fetchpriority="high" alt={heroAlt} />
    )}
    <div class="container ls-hero__inner">
      <span class="ls-hero__eyebrow">{lang === 'es' ? `Sirviendo ${cityName}, FL` : `Serving ${cityName}, FL`}</span>
      <h1>{h1}</h1>
      {heroParagraph && <p class="ls-hero__sub">{heroParagraph}</p>}
      <div class="ls-hero__ctas">
        <a class="btn btn--primary btn--lg" href={localizedHref('/contact-us', lang)}>{t('cta.requestEstimate')}</a>
        <a class="btn btn--ghost btn--lg ls-hero__ghost" href={localizedHref('/project-estimator', lang)}>{t('cta.tryEstimator')}</a>
      </div>
      <TrustBadges lang={lang} variant="hero" reveal={false} class="ls-hero__badges" />
    </div>
  </section>

  <!-- GEO/AEO direct answer (city-named, real pricing from the estimator engine) -->
  <AnswerBlock
    lang={lang}
    question={answerQ}
    answer={answerA}
    alt={true}
    image={answerImg}
    imageAlt={`${meta.label[lang]} ${inWord} ${cityName}, ${county} — AB Aluminum & Screens`}
    chips={[
      { icon: 'ruler', value: lang === 'es' ? `desde $${perSqft}/pie²` : `from $${perSqft}/sq ft`, label: lang === 'es' ? 'instalado' : 'installed' },
      { icon: 'wind', value: '175 mph', label: lang === 'es' ? 'resistencia HVHZ' : 'HVHZ wind-rated' },
      { icon: 'clock', value: lang === 'es' ? '2–4 sem' : '2–4 wks', label: lang === 'es' ? 'construcción típica' : 'typical build' },
      { icon: 'box', value: lang === 'es' ? 'Gratis' : 'Free', label: lang === 'es' ? 'diseño 3D' : '3D design' },
    ]}
  />

  <!-- Unique local value section (the anti-doorway content — dominates the page) -->
  {(introHeading || valueParagraphs.length > 0) && (
    <section class="section">
      <div class="container ls-local">
        <h2 class="ls-local__h">{introHeading || `${meta.label[lang]} ${inWord} ${cityName}`}</h2>
        {neighborhoods.length > 0 && (
          <p class="ls-local__hoods"><strong>{areaChipsH}:</strong> {neighborhoods.join(' · ')}</p>
        )}
        <div class="ls-local__body">
          {valueParagraphs.map((p) => <p>{p}</p>)}
        </div>
        {(permitNote || localProof) && (
          <div class="ls-callouts">
            {permitNote && (
              <div class="ls-callout">
                <h3>{permitH}</h3>
                <p>{permitNote}</p>
              </div>
            )}
            {localProof && (
              <div class="ls-callout ls-callout--proof">
                <p>{localProof}</p>
              </div>
            )}
          </div>
        )}
      </div>
    </section>
  )}

  <StatsBand lang={lang} />

  <!-- Real project photos (shared service gallery strip) -->
  {stripImgs.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <div class="grid cols-4">
          {stripImgs.slice(0, 4).map((img: any) => (
            <SanityImg image={img} width={420} class="ls-strip-img" alt={img.alt || `${meta.label[lang]} ${inWord} ${cityName}`} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Featured / Colors two-column (shared service content, localized) -->
  {featLoc.heading && (
    <section class="section">
      <div class="container ls-two ls-two--rev">
        <div class="ls-two__text">
          <h2>{featLoc.heading}</h2>
          <PortableText value={featLoc.body} />
        </div>
        {featuredImg && <SanityImg image={featuredImg} width={560} class="img-frame" alt={featuredImg.alt || featLoc.heading || ''} />}
      </div>
    </section>
  )}
  {colorsLoc.heading && (
    <section class="section section--alt">
      <div class="container ls-two">
        <div class="ls-two__text">
          <h2>{colorsLoc.heading}</h2>
          <PortableText value={colorsLoc.body} />
        </div>
        {colorsImg && <SanityImg image={colorsImg} width={560} class="img-frame" alt={colorsImg.alt || colorsLoc.heading || ''} />}
      </div>
    </section>
  )}

  <GalleryMosaic lang={lang} sub={galleryP} />
  <FeatureGrid lang={lang} alt={true} />
  <ProcessSteps lang={lang} />
  <FinancingTeaser lang={lang} alt={true} />
  <Reviews lang={lang} limit={3} />

  <!-- Internal linking: nearby-same-service + other-services-same-city + hubs -->
  {(neighbors.length > 0 || otherServices.length > 0) && (
    <section class="section section--alt">
      <div class="container narrow text-center ls-links">
        {neighbors.length > 0 && (
          <div class="ls-links__group">
            <h2>{nearbyH2}</h2>
            <ul class="ls-chips" data-reveal>
              {neighbors.map((n) => (
                <li>
                  <a href={localizedHref('/' + route + '/' + n.slug, lang)}>
                    {meta.label[lang]} {inWord} {(lang === 'es' && n.titleEs) || n.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
        {otherServices.length > 0 && (
          <div class="ls-links__group">
            <h2>{otherH2}</h2>
            <ul class="ls-chips" data-reveal>
              {otherServices.map((r) => {
                const m = SERVICES.find((s) => s.route === r)!;
                return (
                  <li>
                    <a href={localizedHref('/' + r + '/' + citySlug, lang)}>{m.label[lang]} {inWord} {cityName}</a>
                  </li>
                );
              })}
            </ul>
          </div>
        )}
        <div class="ls-links__hubs">
          <a class="btn btn--ghost" href={localizedHref('/service-areas/' + citySlug, lang)}>
            {lang === 'es' ? `Todos los servicios en ${cityName}` : `All services in ${cityName}`}
          </a>
          <a class="btn btn--ghost" href={localizedHref('/' + route, lang)}>
            {lang === 'es' ? `Más sobre ${meta.label[lang]}` : `More about ${meta.label[lang]}`}
          </a>
        </div>
      </div>
    </section>
  )}

  <FAQ lang={lang} items={faqs} alt={false} />

  <CtaStrip lang={lang} />
  <LeadSection lang={lang} source={`local:${route}:${citySlug}`} alt={true} service={LEAD_SERVICE[route]} />
</BaseLayout>

<style>
  /* Hero — dark image + brand scrim, centered (mirrors the service-page hero) */
  .ls-hero {
    position: relative;
    color: #fff;
    background: var(--charcoal);
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: clamp(440px, 60vh, 580px);
    padding-block: clamp(3rem, 8vw, 6rem);
  }
  :global(.ls-hero__bg) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.42;
  }
  .ls-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(rgba(8, 8, 20, 0.58), rgba(8, 8, 20, 0.7)),
      radial-gradient(ellipse 85% 75% at 50% 45%, rgba(8, 8, 20, 0.35), transparent 72%);
  }
  .ls-hero__inner {
    position: relative;
    z-index: 2;
    max-width: 780px;
    margin-inline: auto;
    text-align: center;
  }
  .ls-hero__eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--peach-2);
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.32);
    border: 1px solid rgba(255, 255, 255, 0.22);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    margin-bottom: 1.1rem;
  }
  .ls-hero h1 {
    color: #fff;
    text-wrap: balance;
    text-shadow: 0 2px 22px rgba(0, 0, 0, 0.28);
  }
  .ls-hero__sub {
    font-size: 1.0625rem;
    line-height: 1.65;
    margin: 1.15rem auto 0;
    max-width: 620px;
    color: rgba(255, 255, 255, 0.92);
    text-wrap: pretty;
  }
  .ls-hero__ctas {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 2rem;
  }
  .ls-hero__ghost {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.6);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
  }
  .ls-hero__ghost:hover {
    background: #fff;
    color: var(--charcoal);
    border-color: #fff;
  }
  .ls-hero :global(.ls-hero__badges) {
    justify-content: center;
    margin-top: 1.9rem;
  }

  /* Local value section */
  .ls-local {
    max-width: 820px;
  }
  .ls-local__h {
    text-wrap: balance;
  }
  .ls-local__hoods {
    margin-top: 0.75rem;
    color: var(--muted);
    font-size: 0.95rem;
  }
  .ls-local__body {
    margin-top: 1.25rem;
    display: grid;
    gap: 1.1rem;
  }
  .ls-local__body p {
    line-height: 1.7;
    color: var(--charcoal);
  }
  .ls-callouts {
    margin-top: 1.75rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .ls-callout {
    background: var(--light-gray);
    border: 1px solid var(--border);
    border-left: 4px solid var(--blue);
    border-radius: var(--radius);
    padding: 1.25rem 1.4rem;
  }
  .ls-callout h3 {
    font-size: 1.05rem;
    margin-bottom: 0.4rem;
  }
  .ls-callout p {
    color: var(--muted);
    line-height: 1.6;
    font-size: 0.95rem;
  }
  .ls-callout--proof {
    border-left-color: var(--red);
    font-style: italic;
  }

  /* Shared strip + two-column (mirrors service page) */
  :global(.ls-strip-img) {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 8px;
  }
  .ls-two {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }
  .ls-two img {
    width: 100%;
  }
  .ls-two__text {
    min-width: 0;
  }
  .ls-two--rev .ls-two__text {
    order: 2;
  }

  /* Internal links */
  .ls-links__group {
    margin-bottom: 2rem;
  }
  .ls-chips {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
  }
  .ls-chips a {
    display: inline-block;
    padding: 0.5rem 0.95rem;
    border-radius: 999px;
    background: #fff;
    border: 1px solid var(--border);
    font-weight: 600;
    font-size: 0.875rem;
    transition: border-color 0.18s ease, color 0.18s ease;
  }
  .ls-chips a:hover {
    border-color: var(--red);
    color: var(--red);
  }
  .ls-links__hubs {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  @media (max-width: 860px) {
    .ls-two {
      grid-template-columns: 1fr;
    }
    .ls-two--rev .ls-two__text {
      order: 0;
    }
    .ls-callouts {
      grid-template-columns: 1fr;
    }
  }
</style>
