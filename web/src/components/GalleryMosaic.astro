---
import { localizedHref, type Lang } from '../lib/i18n';
import { SERVICES } from '../lib/nav';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
  eyebrow?: string;
  heading?: string;
  sub?: string;
}
const { lang, eyebrow, heading, sub } = Astro.props;

const copy = {
  en: {
    eyebrow: 'Gallery',
    heading: 'Recent Projects from Miami-Dade, Broward & Palm Beach',
    sub: 'Real aluminum pergolas, pool enclosures, screen rooms and louvered roofs we designed, permitted and installed across South Florida.',
    view: (label: string) => `View ${label} Gallery`,
  },
  es: {
    eyebrow: 'Galería',
    heading: 'Proyectos Recientes en Miami-Dade, Broward y Palm Beach',
    sub: 'Pérgolas de aluminio, cerramientos de piscina, porches con malla y techos de lamas que diseñamos, tramitamos e instalamos en el sur de Florida.',
    view: (label: string) => `Ver galería de ${label}`,
  },
};
const c = copy[lang];

// 2×2 category tiles, sourced from the canonical service list.
const tileImg: Record<string, string> = {
  pergolas: '/images/Pergolas-Gallery.avif',
  'pool-enclosure': '/images/Pool-Enclosure-gallery.avif',
  'patio-screens': '/images/Patio-Screen-Gallery.avif',
  'louvered-roof-systems': '/images/Louvered-Roof-Systems.avif',
};
const tiles = SERVICES.map((s) => ({
  href: localizedHref('/gallery/' + s.gallery, lang),
  label: s.label[lang],
  img: tileImg[s.gallery],
}));
---
<section class="mosaic-wrap" aria-label={c.eyebrow}>
  <div class="mosaic" data-reveal>
    <!-- LEFT: tall lifestyle photo + frosted glass heading card -->
    <div class="mosaic__feature zoom">
      <img
        src="/images/aluminum-pergola-louvers-patio-pool-tropical-plants-florida.avif"
        alt={lang === 'es'
          ? 'Pérgola de aluminio con lamas junto a una piscina en el sur de Florida'
          : 'Aluminum louvered pergola beside a pool in South Florida'}
        width="900"
        height="1000"
        loading="lazy"
      />
      <div class="mosaic__card">
        <span class="eyebrow eyebrow--line">{eyebrow ?? c.eyebrow}</span>
        <h2>{heading ?? c.heading}</h2>
        <p>{sub ?? c.sub}</p>
      </div>
    </div>

    <!-- RIGHT: 2×2 overlaid category tiles -->
    <div class="mosaic__tiles">
      {
        tiles.map((tile) => (
          <a class="tile zoom" href={tile.href}>
            <img src={tile.img} alt={tile.label} width="640" height="420" loading="lazy" />
            <div class="tile__overlay">
              <h3>{tile.label}</h3>
              <span class="tile__link">
                {c.view(tile.label)}
                <Icon name="arrow-right" size={16} />
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .mosaic-wrap {
    --gap: 6px;
    --mh: clamp(560px, 56vw, 720px);
    /* Full-bleed photo band: zero vertical padding so it sits flush between its
       neighbours — each adjacent section supplies the gap in ITS OWN background
       colour, avoiding a two-tone white band against grey sections. */
    padding-block: 0;
  }
  .mosaic {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--gap);
    height: var(--mh);
  }

  /* Feature */
  .mosaic__feature {
    position: relative;
    border-radius: 0;
    overflow: hidden;
  }
  .mosaic__feature > img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .mosaic__card {
    position: absolute;
    left: clamp(1rem, 3vw, 2.5rem);
    bottom: clamp(1rem, 3vw, 2.5rem);
    right: clamp(1rem, 6vw, 6rem);
    max-width: 460px;
    background: var(--glass-bg);
    -webkit-backdrop-filter: blur(var(--glass-blur));
    backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    padding: clamp(1.25rem, 2.5vw, 2rem);
    box-shadow: var(--shadow-glass);
  }
  .mosaic__card h2 {
    font-size: var(--h2);
    margin-top: 0.3rem;
  }
  .mosaic__card p {
    margin-top: 0.6rem;
    color: var(--text-muted);
    font-size: 0.9375rem;
  }

  /* Tiles */
  .mosaic__tiles {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: var(--gap);
  }
  .tile {
    position: relative;
    overflow: hidden;
    display: block;
    color: #fff;
  }
  .tile > img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .tile::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--scrim);
    z-index: 1;
    transition: opacity 0.35s var(--ease);
  }
  .tile:hover::before {
    opacity: 0.78;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.92) 0%, rgba(0, 0, 0, 0.45) 55%, rgba(0, 0, 0, 0.1) 100%);
  }
  .tile__overlay {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 2;
    padding: clamp(1rem, 2vw, 1.5rem);
  }
  .tile__overlay h3 {
    color: #fff;
    font-size: var(--h3);
  }
  .tile__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.45rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: #fff;
    border-bottom: 2px solid var(--red);
    padding-bottom: 2px;
    transition: gap 0.25s var(--ease);
  }
  .tile:hover .tile__link {
    gap: 0.7rem;
  }
  .tile:hover {
    color: #fff;
  }

  /* Mobile: stack the glass-card image, then the 4 tiles in one column. Keep overlays. */
  @media (max-width: 820px) {
    .mosaic-wrap {
      --mh: auto;
    }
    .mosaic {
      grid-template-columns: 1fr;
      height: auto;
    }
    .mosaic__feature {
      height: clamp(360px, 70vw, 460px);
    }
    .mosaic__tiles {
      grid-template-columns: 1fr;
      grid-template-rows: none;
    }
    .tile {
      height: clamp(220px, 56vw, 300px);
    }
    .mosaic__card {
      right: clamp(1rem, 6vw, 2rem);
    }
  }
</style>
