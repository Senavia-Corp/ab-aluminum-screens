---
import { useT, type Lang } from '../lib/i18n';
import { SERVICES } from '../lib/nav';
import { TURNSTILE_SITE_KEY } from '../lib/turnstile';

interface Props {
  lang: Lang;
  source?: string;
  compact?: boolean;
  defaultInterest?: string;
}
const { lang, source = 'inline', compact = false, defaultInterest = '' } = Astro.props;
const t = useT(lang);
const timelines = [
  { v: 'immediately', l: t('form.timelineNow') },
  { v: '1-3-months', l: t('form.timeline13') },
  { v: '3-plus-months', l: t('form.timeline3plus') },
  { v: 'researching', l: t('form.timelineResearch') },
];
---

<form class:list={['lead-form', { 'lead-form--compact': compact }]} data-source={source} data-locale={lang} novalidate>
  <div class="lead-form__grid">
    <div class="field">
      <label for="lf-name">{t('form.fullName')} *</label>
      <input id="lf-name" name="name" type="text" autocomplete="name" required />
    </div>
    <div class="field">
      <label for="lf-email">{t('form.email')} *</label>
      <input id="lf-email" name="email" type="email" autocomplete="email" required />
    </div>
    <div class="field">
      <label for="lf-phone">{t('form.phone')} *</label>
      <input id="lf-phone" name="phone" type="tel" autocomplete="tel" required />
    </div>
    <div class="field">
      <label for="lf-zip">{t('form.zip')}</label>
      <input id="lf-zip" name="zip" type="text" inputmode="numeric" autocomplete="postal-code" />
    </div>
    <div class="field">
      <label for="lf-city">{t('form.city')}</label>
      <input id="lf-city" name="city" type="text" autocomplete="address-level2" />
    </div>
    <div class="field">
      <label for="lf-interest">{t('form.projectInterest')}</label>
      <select id="lf-interest" name="interest">
        <option value="">{t('form.selectOne')}</option>
        {SERVICES.map((s) => (
          <option value={s.route} selected={s.route === defaultInterest}>
            {s.label[lang]}
          </option>
        ))}
        <option value="not-sure">{t('wizard.notSure')}</option>
      </select>
    </div>
    <div class="field">
      <label for="lf-timeline">{t('form.timeline')}</label>
      <select id="lf-timeline" name="timeline">
        <option value="">{t('form.selectOne')}</option>
        {timelines.map((x) => <option value={x.v}>{x.l}</option>)}
      </select>
    </div>
  </div>
  <div class="field">
    <label for="lf-message">{t('form.message')}</label>
    <textarea id="lf-message" name="message" rows="3"></textarea>
  </div>
  {/* Honeypot — hidden from humans & a11y tree; bots that fill it get a silent no-op server-side. */}
  <div class="lead-form__hp" aria-hidden="true">
    <label for="lf-company-url">Company URL</label>
    <input id="lf-company-url" name="company_url" type="text" tabindex="-1" autocomplete="off" />
  </div>
  {/* Cloudflare Turnstile — invisible/managed human check; injects a hidden cf-turnstile-response token. */}
  <div class="cf-turnstile lead-form__ts" data-sitekey={TURNSTILE_SITE_KEY} data-size="flexible"></div>
  <button class="btn btn--primary btn--lg btn--block" type="submit">{t('form.submit')}</button>
  <p class="lead-form__status" role="status" aria-live="polite" hidden></p>
</form>

<script is:inline>
  // Load Turnstile once per page even if multiple lead forms are present.
  if (!window.__tsLoading) {
    window.__tsLoading = true;
    const s = document.createElement('script');
    s.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
    s.async = true;
    s.defer = true;
    document.head.appendChild(s);
  }
</script>

<style>
  .lead-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 1rem;
  }
  .lead-form--compact .lead-form__grid {
    grid-template-columns: 1fr;
  }
  .lead-form__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .lead-form__ts {
    margin-top: 1rem;
  }
  .lead-form__status {
    margin-top: 0.875rem;
    padding: 0.875rem 1rem;
    border-radius: var(--radius);
    font-weight: 600;
  }
  .lead-form__status[data-kind='ok'] {
    background: var(--success-bg);
    color: var(--success);
  }
  .lead-form__status[data-kind='err'] {
    background: var(--peach);
    color: var(--charcoal);
    border-left: 3px solid var(--red);
  }
  @media (max-width: 560px) {
    .lead-form__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const T = {
    en: {
      required: 'Please complete the required fields.',
      email: 'Please enter a valid email.',
      sending: 'Sending…',
      ok: 'Thank you! We’ve received your request and will contact you within 24 hours.',
      err: 'Something went wrong. Please call us or try again.',
    },
    es: {
      required: 'Por favor completa los campos obligatorios.',
      email: 'Ingresa un correo válido.',
      sending: 'Enviando…',
      ok: '¡Gracias! Recibimos tu solicitud y te contactaremos en 24 horas.',
      err: 'Algo salió mal. Por favor llámanos o intenta de nuevo.',
    },
  };

  document.querySelectorAll<HTMLFormElement>('.lead-form').forEach((form) => {
    const locale = (form.dataset.locale === 'es' ? 'es' : 'en') as 'en' | 'es';
    const tr = T[locale];
    const status = form.querySelector<HTMLParagraphElement>('.lead-form__status')!;
    const btn = form.querySelector<HTMLButtonElement>('button[type=submit]')!;
    const btnLabel = btn.textContent;
    const loadedAt = Date.now();

    const setStatus = (msg: string, kind: 'ok' | 'err') => {
      status.textContent = msg;
      status.dataset.kind = kind;
      status.hidden = false;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form).entries());
      const turnstileToken = String(data['cf-turnstile-response'] || '');
      delete data['cf-turnstile-response'];
      if (!data.name || !data.email || !data.phone) {
        setStatus(tr.required, 'err');
        return;
      }
      if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(String(data.email))) {
        setStatus(tr.email, 'err');
        return;
      }
      btn.disabled = true;
      btn.textContent = tr.sending;
      try {
        const res = await fetch('/api/lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            type: form.dataset.source || 'inline',
            locale,
            sourcePage: location.pathname,
            payload: data,
            turnstileToken,
            elapsedMs: Date.now() - loadedAt,
          }),
        });
        if (!res.ok) throw new Error('bad status');
        // ponytail: only a genuinely saved lead returns an id. The honeypot and time-trap
        // in api/lead.ts return 200 {ok:true} WITHOUT an id (silent bot no-op), so gating on
        // res.ok alone redirected bots to /thank-you and fired a phantom Ads conversion.
        const result = await res.json().catch(() => ({}));
        if (!result.id) throw new Error('not saved');
        const home = locale === 'es' ? '/es/thank-you' : '/thank-you';
        window.location.href = home;
      } catch {
        setStatus(tr.err, 'err');
        btn.disabled = false;
        btn.textContent = btnLabel;
        window.turnstile?.reset?.();
      }
    });
  });
</script>
