---
import { useT, type Lang } from '../lib/i18n';
import { TESTIMONIALS } from '../lib/testimonials';
import SectionHeading from './SectionHeading.astro';
import Icon from './Icon.astro';

interface Props {
  lang: Lang;
  alt?: boolean;
  limit?: number;
}
const { lang, alt = false, limit = 8 } = Astro.props;
const t = useT(lang);
const items = TESTIMONIALS.slice(0, limit);
const badgeText = lang === 'es' ? 'Basado en reseñas de Google' : 'Based on Google reviews';
const prevLabel = lang === 'es' ? 'Anterior' : 'Previous';
const nextLabel = lang === 'es' ? 'Siguiente' : 'Next';
const trackLabel = lang === 'es' ? 'Reseñas de clientes' : 'Customer reviews';
---
<section class:list={['section', { 'section--alt': alt }]}>
  <div class="container">
    <SectionHeading eyebrow={t('reviews.eyebrow')} heading={t('reviews.heading')} />

    <div class="gbadge" data-reveal>
      <span class="gbadge__g" aria-hidden="true">G</span>
      <span class="gbadge__rating">4.9</span>
      <span class="gbadge__stars" role="img" aria-label="4.9 out of 5">
        {[0, 1, 2, 3, 4].map(() => <Icon name="star" solid size={16} />)}
      </span>
      <span class="gbadge__text">{badgeText}</span>
    </div>

    {/* Live reviews widget mounts here (Google / Elfsight). Client adds their widget id. */}
    <div class="reviews-embed" data-reviews-widget aria-hidden="true"></div>

    <div class="rev" data-reveal>
      <div class="rev-track" data-rev-track tabindex="0" role="group" aria-label={trackLabel}>
        {
          items.map((r) => (
            <figure class="card review">
              <Icon name="message-circle" size={22} class="review__mark" />
              <div class="review__stars" role="img" aria-label={`${r.rating} out of 5`}>
                {Array.from({ length: r.rating }).map(() => <Icon name="star" solid size={16} />)}
              </div>
              <blockquote class="review__quote">{r.quote[lang]}</blockquote>
              <figcaption class="review__by">
                <span class="review__avatar" aria-hidden="true">{r.name.charAt(0)}</span>
                <span>
                  <strong>{r.name}</strong>
                  <span class="review__city">{r.city}</span>
                </span>
              </figcaption>
            </figure>
          ))
        }
      </div>
      <div class="rev-ctrls">
        <button type="button" class="rev-btn" data-rev-prev aria-label={prevLabel}>
          <Icon name="arrow-right" size={20} class="flip" />
        </button>
        <button type="button" class="rev-btn" data-rev-next aria-label={nextLabel}>
          <Icon name="arrow-right" size={20} />
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .gbadge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin: 1.5rem auto 0;
    padding: 0.6rem 1.1rem;
    border-radius: 999px;
    background: #fff;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    width: fit-content;
    margin-inline: auto;
  }
  .section .gbadge {
    display: flex;
  }
  .gbadge__g {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: conic-gradient(from -45deg, #ea4335, #fbbc05, #34a853, #4285f4, #ea4335);
    color: #fff;
    font-weight: 900;
    display: grid;
    place-items: center;
    font-size: 0.9375rem;
  }
  .gbadge__rating {
    font-weight: 800;
    font-size: 1.0625rem;
  }
  .gbadge__stars {
    display: inline-flex;
    color: #f5a623;
    gap: 1px;
  }
  .gbadge__text {
    color: var(--muted);
    font-size: 0.875rem;
  }

  .rev {
    position: relative;
    margin-top: 2.5rem;
  }
  .rev-track {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding: 0.5rem 0.25rem 1.25rem;
    scrollbar-width: none;
  }
  .rev-track::-webkit-scrollbar {
    display: none;
  }
  .review {
    flex: 0 0 clamp(260px, 32%, 360px);
    scroll-snap-align: start;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
  }
  .review__mark {
    color: var(--peach);
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
  }
  .review__stars {
    display: inline-flex;
    color: #f5a623;
    gap: 1px;
  }
  .review__quote {
    margin: 0;
    line-height: 1.65;
    color: var(--charcoal);
    flex: 1;
  }
  .review__by {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .review__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--blue);
    color: #fff;
    font-weight: 800;
    display: grid;
    place-items: center;
    flex: none;
  }
  .review__by strong {
    display: block;
  }
  .review__city {
    color: var(--muted);
    font-size: 0.875rem;
  }
  .rev-ctrls {
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    margin-top: 0.5rem;
  }
  .rev-btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: #fff;
    color: var(--charcoal);
    display: grid;
    place-items: center;
    cursor: pointer;
    transition: background 0.18s var(--ease), color 0.18s var(--ease), border-color 0.18s var(--ease);
  }
  .rev-btn:hover {
    background: var(--red);
    color: #fff;
    border-color: var(--red);
  }
  .rev-btn :global(.flip) {
    transform: scaleX(-1);
  }
  .reviews-embed:empty {
    display: none;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-rev-track]').forEach((track) => {
    const root = track.parentElement!;
    const prev = root.querySelector<HTMLButtonElement>('[data-rev-prev]');
    const next = root.querySelector<HTMLButtonElement>('[data-rev-next]');
    const step = () => {
      const card = track.querySelector<HTMLElement>('.review');
      return card ? card.offsetWidth + 20 : 320;
    };
    prev?.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
    next?.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
  });
</script>
