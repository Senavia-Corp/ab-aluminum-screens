---
/**
 * Reusable FAQ accordion + the single FAQPage JSON-LD emitter for a page.
 * Visible text is identical to the schema (same `items`). One FAQ per page = one FAQPage node.
 * ponytail: native <details>, no JS. Set emitSchema={false} if a page already emits FAQPage elsewhere.
 */
import type { Lang } from '../lib/i18n';
import SectionHeading from './SectionHeading.astro';

interface Props {
  lang: Lang;
  items: { q: string; a: string }[];
  heading?: string;
  eyebrow?: string;
  alt?: boolean;
  emitSchema?: boolean;
}
const { lang, items, heading, eyebrow, alt = false, emitSchema = true } = Astro.props;
const h = heading ?? (lang === 'es' ? 'Preguntas Frecuentes' : 'Frequently Asked Questions');
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
{
  items.length > 0 && (
    <section class:list={['section', { 'section--alt': alt }]}>
      <div class="container narrow">
        {eyebrow ? <SectionHeading eyebrow={eyebrow} heading={h} /> : <h2 class="text-center">{h}</h2>}
        <div class="faq" data-reveal>
          {items.map((f) => (
            <details class="faq__item">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
      {emitSchema && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
    </section>
  )
}

<style>
  .faq {
    margin-top: 1.5rem;
  }
  .faq__item {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
    background: #fff;
  }
  .faq__item summary {
    font-weight: 700;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .faq__item summary::-webkit-details-marker {
    display: none;
  }
  .faq__item summary::after {
    content: '+';
    color: var(--red);
    font-size: 1.5rem;
    line-height: 1;
    font-weight: 400;
    flex: none;
  }
  .faq__item[open] summary::after {
    content: '\2212'; /* minus */
  }
  .faq__item p {
    margin-top: 0.75rem;
    color: var(--muted);
    line-height: 1.6;
  }
</style>
