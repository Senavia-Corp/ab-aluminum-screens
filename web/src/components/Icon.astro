const fill = solid ? 'currentColor' : 'none';
const strokeAttr = solid ? '0' : String(stroke);
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={fill}
  stroke="currentColor"
  stroke-width={strokeAttr}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={`icon ${cls}`}
  aria-hidden="true"
  focusable="false"
  set:html={inner}
/>
